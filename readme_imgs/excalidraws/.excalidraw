    {
      "id": "5y6RaShSb5pdbowKkyr3r",
      "type": "text",
      "x": 949.723731,
      "y": 332.500000279711,
      "width": 319,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
